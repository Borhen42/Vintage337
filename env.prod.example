# Copy to .env next to docker-compose.prod.yml:  cp env.prod.example .env
# See DEPLOY-VPS.md

# Default matches local docker-compose.yml; set a strong password in production.
POSTGRES_PASSWORD=postgres
JWT_SECRET=use-at-least-32-characters-here-please
API_PORT=8080

# Comma-separated; must include your SPA origin (e.g. Vercel URL)
APP_CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:4200
APP_FRONTEND_URL=https://your-app.vercel.app
# Public base URL of the API (no trailing slash). Use https:// after Caddy/nginx TLS.
APP_PUBLIC_URL=https://api.example.com
